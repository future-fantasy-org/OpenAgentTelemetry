# ─── Server (apps/server) ─────────────────────────────────
# PostgreSQL 连接串（必填）
DATABASE_URL=postgresql://oat:oat@localhost:5432/oat

# 后端监听端口
PORT=3001

# JWT 签名密钥（必填）：生产环境务必改成随机长字符串
# 生成：openssl rand -hex 32
JWT_SECRET=

# AES-256-GCM 密钥（M13 必填）：用于加密 Provider API Key
# 生成：openssl rand -base64 32（解码后必须恰好 32 字节）
ENCRYPTION_KEY=

# 引导管理员：server 启动时若 users 表无此 email 则自动创建（幂等）
ADMIN_EMAIL=admin@oat.dev
ADMIN_PASSWORD=admin123

# ─── Web (apps/web) ───────────────────────────────────────
# 前端 SSR 访问后端的地址
SERVER_URL=http://localhost:3001

# ─── SDK ─────────────────────────────────────────────────
# SDK 上报目标地址
OAT_BASE_URL=http://localhost:3001
OAT_API_KEY=
